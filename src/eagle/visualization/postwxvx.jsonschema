{
  "$defs": {
    "datetime": {
      "anyOf": [
        {
          "type": "datetime"
        },
        {
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}$",
          "type": "string"
        }
      ]
    },
    "timedelta": {
      "anyOf": [
        {
          "type": "timedelta"
        },
        {
          "type": "integer"
        },
        {
          "pattern": "^[0-9]+(:[0-9]+(:[0-9]+)?)?$",
          "type": "string"
        }
      ]
    }
  },
  "properties": {
    "postwxvx": {
      "properties": {
        "eagle_tools": {
          "properties": {
            "end_date": {
              "$ref": "#/$defs/datetime"
            },
            "freq": {
              "type": "string"
            },
            "leadtimes": {
              "properties": {
                "end": {
                  "type": "integer"
                },
                "start": {
                  "type": "integer"
                },
                "step": {
                  "type": "integer"
                }
              },
              "type": "object"
            },
            "start_date": {
              "$ref": "#/$defs/datetime"
            },
            "stat_prefix": {
              "type": "string"
            },
            "variable_prefixes": {
              "type": "array"
            },
            "work_path": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "execution": {
          "$ref": "urn:uwtools:execution-serial"
        },
        "name": {
          "type": "string"
        },
        "rundir": {
          "type": "string"
        }
      },
      "required": [
        "eagle_tools",
        "execution",
        "name",
        "rundir"
      ],
      "type": "object"
    }
  },
  "required": [
    "postwxvx"
  ],
  "type": "object"
}
